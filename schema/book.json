{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://heterarchy.fyi/schema/book.json",
  "type": "object",
  "required": ["id", "title", "author", "description", "language", "formats", "physical", "links"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9\\-]+$"
    },
    "title": { "type": "string", "minLength": 1 },
    "author": { "type": "string", "minLength": 1 },
    "year": { "type": "string" },
    "coverUrl": { "type": "string" },
    "description": { "type": "string", "minLength": 1 },
    "language": {
      "type": "array",
      "items": { "type": "string", "enum": ["en", "cs", "de"] },
      "minItems": 1
    },
    "formats": {
      "type": "array",
      "items": { "type": "string", "enum": ["ebook", "pdf", "web", "print"] },
      "minItems": 1
    },
    "physical": { "type": "boolean" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["href", "label"],
        "additionalProperties": false,
        "properties": {
          "href": { "type": "string" },
          "label": { "type": "string" },
          "external": { "type": "boolean" }
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["name", "href"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "href": { "type": "string" }
      }
    }
  }
}
