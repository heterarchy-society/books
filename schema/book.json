{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://heterarchy.fyi/schema/book.json",
  "type": "object",
  "required": ["id", "title", "authors", "description", "language", "formats", "physical", "links"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9\\-]+$"
    },
    "title": { "type": "string", "minLength": 1 },
    "authors": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "year": { "type": "string" },
    "cover": {
      "type": "string",
      "pattern": "^cover\\.(png|jpe?g|webp|gif)$",
      "description": "Cover image filename in the book directory"
    },
    "description": { "type": "string", "minLength": 1 },
    "language": {
      "type": "array",
      "items": { "type": "string", "enum": ["en", "cs", "de"] },
      "minItems": 1
    },
    "formats": {
      "type": "array",
      "items": { "type": "string", "enum": ["ebook", "pdf", "web", "print"] },
      "minItems": 1
    },
    "physical": { "type": "boolean" },
    "glossary": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9\\-]+$"
      },
      "uniqueItems": true
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["href", "label"],
        "additionalProperties": false,
        "properties": {
          "href": { "type": "string" },
          "label": { "type": "string" },
          "external": { "type": "boolean" }
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["name", "href"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "href": { "type": "string" }
      }
    }
  }
}
